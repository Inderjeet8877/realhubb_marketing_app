rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── WhatsApp conversations ─────────────────────────────────────────
    // write = true  → webhook can write without user auth
    // read  = true  → dashboard and API routes can read freely
    match /whatsapp_conversations/{docId} {
      allow read, write: if true;
    }

    // ── Webhook diagnostic logs ────────────────────────────────────────
    match /webhook_logs/{docId} {
      allow read, write: if true;
    }

    // ── WhatsApp templates ─────────────────────────────────────────────
    match /whatsapp_templates/{docId} {
      allow read, write: if true;
    }

    // ── Users ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);

      match /adAccounts/{accountId} {
        allow read, write: if isOwner(userId);
      }
      match /whatsappNumbers/{numberId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Contacts ───────────────────────────────────────────────────────
    match /contacts/{contactId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ── Campaigns ──────────────────────────────────────────────────────
    match /campaigns/{campaignId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ── Message logs ───────────────────────────────────────────────────
    match /messageLogs/{logId} {
      allow read, create, update: if isAuthenticated();
    }
  }
}
